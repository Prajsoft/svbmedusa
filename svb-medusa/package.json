{
  "name": "svb-medusa",
  "version": "1.0.0",
  "description": "SVB Sports — Medusa v2 commerce backend for cricket equipment e-commerce",
  "author": "SVB Sports",
  "license": "MIT",
  "keywords": [
    "postgres",
    "typescript",
    "ecommerce",
    "headless",
    "medusa",
    "cricket",
    "svb-sports"
  ],
  "scripts": {
    "build": "medusa build",
    "postbuild": "node scripts/patch-medusa-types.js",
    "patch:types": "node scripts/patch-medusa-types.js",
    "predeploy": "medusa db:migrate",
    "seed": "medusa exec ./src/scripts/seed.ts",
    "search:sync": "medusa exec ./src/scripts/sync-products-to-search.ts",
    "seed:tax": "medusa exec ./src/scripts/seed-tax.ts",
    "start": "medusa start --host 0.0.0.0",
    "dev": "medusa develop",
    "clean:generated": "git restore --worktree -- .medusa/server .medusa/types/query-entry-points.d.ts",
    "check:docs:shipping": "node scripts/check-shipping-docs.js",
    "test:integration:http": "TEST_TYPE=integration:http NODE_OPTIONS=--experimental-vm-modules jest --silent=false --runInBand --forceExit",
    "test:integration:modules": "TEST_TYPE=integration:modules NODE_OPTIONS=--experimental-vm-modules jest --silent=false --runInBand --forceExit",
    "test:unit": "TEST_TYPE=unit NODE_OPTIONS=--experimental-vm-modules jest --silent --runInBand --forceExit"
  },
  "dependencies": {
    "@medusajs/admin-sdk": "2.12.2",
    "@medusajs/cache-redis": "2.12.2",
    "@medusajs/cli": "2.12.2",
    "@medusajs/event-bus-redis": "2.12.2",
    "@medusajs/file": "^2.12.2",
    "@medusajs/file-s3": "^2.12.2",
    "@medusajs/framework": "2.12.2",
    "@medusajs/medusa": "2.12.2",
    "pdfkit": "^0.15.0",
    "razorpay": "^2.9.6",
    "resend": "^6.9.1"
  },
  "devDependencies": {
    "@medusajs/test-utils": "2.12.2",
    "@swc/core": "^1.7.28",
    "@swc/jest": "^0.2.36",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/jest": "^29.5.13",
    "@types/node": "^20.12.11",
    "@types/pdfkit": "^0.13.7",
    "@types/react": "^18.3.2",
    "@types/react-dom": "^18.2.25",
    "@types/supertest": "^6.0.3",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.2.0",
    "prop-types": "^15.8.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.2",
    "vite": "^5.4.14",
    "yalc": "^1.0.0-pre.53"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "yarn@4.9.2+sha512.1fc009bc09d13cfd0e19efa44cbfc2b9cf6ca61482725eb35bbc5e257e093ebf4130db6dfe15d604ff4b79efd8e1e8e99b25fa7d0a6197c9f9826358d4d65c3c"
}
